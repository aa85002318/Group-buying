# Supabase（所有環境必填，勿寫死在程式碼中）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 站台網址
# 開發：可留空，系統會自動使用瀏覽器當前網址（localhost / 手機 LAN IP 皆可）
# 正式／Staging：必填，例如 https://shop.chimeidiy.com
# NEXT_PUBLIC_SITE_URL=
# NEXT_PUBLIC_APP_URL=

# 本機開發允許的 host（逗號分隔，供 Next.js allowedDevOrigins）
ALLOWED_DEV_ORIGINS=localhost,127.0.0.1,192.168.1.109

# 環境識別：development | staging | production
NEXT_PUBLIC_APP_ENV=development

# 客服 Email（驗證信模板、錯誤頁顯示）
SUPPORT_EMAIL=support@chimeidiy.com

# 交易通知信（訂單成立、取貨完成）與註冊驗證信 — 使用 Resend
# https://resend.com 申請 API Key 並驗證寄件網域
# 註冊驗證信由程式寄到「註冊者信箱」，避免 Supabase Gmail SMTP 誤寄到寄件人
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=chimeidiy 團購 <noreply@your-domain.com>

# 金流（Phase 2 — 綠界 ECPay）
# ECPAY_MERCHANT_ID=
# ECPAY_HASH_KEY=
# ECPAY_HASH_IV=
# ECPAY_ENV=test

# 金流（Phase 2 — 藍新 NewebPay）
# NEWEBPAY_MERCHANT_ID=
# NEWEBPAY_HASH_KEY=
# NEWEBPAY_HASH_IV=
# NEWEBPAY_ENV=test

# LINE（麵包小怪獸分享 / LIFF，選用）
NEXT_PUBLIC_LIFF_ID=your-liff-id

# 向下相容（建議改用 NEXT_PUBLIC_SITE_URL）
# NEXT_PUBLIC_APP_URL=http://localhost:3000
